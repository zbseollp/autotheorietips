---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
---
<BaseLayout
  title="Rijbewijs halen — tips & stappenplan | AutotheorieTips"
  description="Hoe haal je je rijbewijs het slimst? Tips over het CBR, rijschool kiezen, examen plannen en kosten besparen."
>
  <section class="bg-teal-800 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px); background-size: 24px 24px;"></div>
    <Container class="relative py-14">
      <div class="text-xs font-bold uppercase tracking-wider text-teal-300 mb-2">AutotheorieTips</div>
      <h1 class="text-4xl font-black tracking-tight">Rijbewijs halen</h1>
      <p class="mt-3 text-teal-200 max-w-xl">Tips en stappenplan: van aanmelden bij het CBR tot je rijbewijs in handen.</p>
    </Container>
    <svg viewBox="0 0 1440 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full -mb-px block" preserveAspectRatio="none">
      <path d="M0 20 C360 0 1080 0 1440 20 L1440 20 L0 20 Z" fill="white"/>
    </svg>
  </section>

  <Container class="max-w-3xl py-(--spacing-section)">

    <!-- Quick tips -->
    <div class="grid gap-4 sm:grid-cols-3 mb-12">
      {[
        { icon: "💡", title: "Doe eerst theorie", body: "Haal eerst je theorie-examen voordat je begint met rijlessen. Scheelt geld." },
        { icon: "🔍", title: "Vergelijk rijscholen", body: "Vraag minimaal 3 offertes op. Prijsverschillen van €500+ zijn normaal." },
        { icon: "⏱️", title: "Plan slim", body: "Examen in de ochtend? Dan minder verkeer en minder stress." },
      ].map(({ icon, title, body }) => (
        <div class="rounded-xl border border-teal-100 bg-teal-50/50 p-5">
          <div class="text-2xl mb-2">{icon}</div>
          <h3 class="font-bold text-slate-900 text-sm mb-1">{title}</h3>
          <p class="text-xs text-slate-500 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>

    <!-- Stappenplan -->
    <div class="mb-12">
      <h2 class="text-2xl font-black tracking-tight text-slate-900 mb-6">Stappenplan rijbewijs B</h2>
      <ol class="space-y-4">
        {[
          { n: "1", title: "Aanvraag CBR-code", body: "Registreer je bij het CBR en vraag een rijbewijscode aan. Dit heb je nodig om je theorie-examen in te plannen. Je betaalt hier eenmalig voor." },
          { n: "2", title: "Theorie leren", body: "Gebruik onze tips om efficiënt te studeren. Besteed extra tijd aan gevaarherkenning en doe regelmatig proefexamens." },
          { n: "3", title: "Theorie-examen doen", body: "Plan je theorie-examen via het CBR. 65 vragen, 45 minuten, slagingsnorm 77%. Zak je? Wacht dan een dag voor je opnieuw plant." },
          { n: "4", title: "Rijschool kiezen", body: "Vergelijk rijscholen op prijs, pakket en locatie. Vraag om een proefles als je twijfelt over de instructeur." },
          { n: "5", title: "Praktijklessen", body: "Gemiddeld 30-40 lessen nodig, maar dat verschilt sterk. Bespreek open met je instructeur wanneer je écht rijklaar bent." },
          { n: "6", title: "Praktijkexamen", body: "Plan via het CBR. Geslaagd? Rijbewijs komt per post. Niet geslaagd? Vraag direct feedback voor de volgende poging." },
        ].map(({ n, title, body }) => (
          <li class="flex gap-4 rounded-xl border border-slate-200 bg-white p-5">
            <div class="shrink-0 w-9 h-9 rounded-full bg-teal-600 text-white flex items-center justify-center font-black text-sm">{n}</div>
            <div>
              <h3 class="font-bold text-slate-900">{title}</h3>
              <p class="mt-1 text-sm text-slate-500 leading-relaxed">{body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <div class="rounded-2xl bg-teal-800 text-white p-8 text-center">
      <h2 class="text-xl font-black tracking-tight mb-2">Begin met de theorie</h2>
      <p class="text-teal-200 text-sm mb-5">Gratis tips en artikelen voor je CBR theorie-examen. Direct beginnen.</p>
      <a href="/blog/" class="inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 text-sm font-bold text-teal-800 hover:bg-teal-50 transition-colors">
        Bekijk alle tips →
      </a>
    </div>
  </Container>
</BaseLayout>
