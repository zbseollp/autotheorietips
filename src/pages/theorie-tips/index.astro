---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getRecentPosts } from "@lib/posts";

const posts = await getRecentPosts(6);
---
<BaseLayout
  title="Theorie tips — slimmer studeren | AutotheorieTips"
  description="De beste theorie tips voor je CBR examen. Leer efficiënt, oefen gevaarherkenning en slaag in één keer."
>
  <section class="bg-teal-700 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px); background-size: 24px 24px;"></div>
    <Container class="relative py-14">
      <div class="text-xs font-bold uppercase tracking-wider text-teal-300 mb-2">AutotheorieTips</div>
      <h1 class="text-4xl font-black tracking-tight">Theorie tips</h1>
      <p class="mt-3 text-teal-200 max-w-xl">Slimme tips om efficiënt te studeren en in één keer te slagen.</p>
    </Container>
    <svg viewBox="0 0 1440 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full -mb-px block" preserveAspectRatio="none">
      <path d="M0 20 C360 0 1080 0 1440 20 L1440 20 L0 20 Z" fill="white"/>
    </svg>
  </section>

  <Container class="py-(--spacing-section)">
    <!-- Tip categories -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 mb-12">
      {[
        { title: "Leerstrategieën", desc: "Hoe plan je je studie? Spreid je leren en oefen op het goede moment.", emoji: "📅" },
        { title: "Gevaarherkenning tips", desc: "Het moeilijkste onderdeel. Onze tips helpen je gevaarlijke situaties sneller te herkennen.", emoji: "⚠️" },
        { title: "Examenstrategie", desc: "Hoe ga je om met twijfelgevallen? Tijdsmanagement en examenstress verminderen.", emoji: "🎯" },
        { title: "Verkeersregels begrijpen", desc: "Begrijp de logica achter regels — dan hoef je minder te stampen.", emoji: "🧠" },
        { title: "Proefexamens", desc: "Wanneer doe je er genoeg? En hoe interpreteer je je resultaten?", emoji: "📝" },
        { title: "Dag van het examen", desc: "Wat te doen de avond voor en ochtend van je examen.", emoji: "✅" },
      ].map(({ title, desc, emoji }) => (
        <a href="/blog/" class="group rounded-2xl border border-teal-100 bg-teal-50/40 p-6 hover:bg-teal-50 hover:border-teal-300 transition-all">
          <div class="text-2xl mb-3">{emoji}</div>
          <h2 class="font-bold text-slate-900 group-hover:text-teal-700 transition-colors">{title}</h2>
          <p class="mt-2 text-sm text-slate-500 leading-relaxed">{desc}</p>
          <div class="mt-4 text-sm font-semibold text-teal-700 flex items-center gap-1">
            Bekijk tips <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div>
      <h2 class="text-2xl font-black tracking-tight text-slate-900 mb-6">Recente tips</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => <BlogPostCard post={p} />)}
      </div>
    </div>
  </Container>
</BaseLayout>
