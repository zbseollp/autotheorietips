---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import { getAllPosts, displayTitle } from "@lib/posts";

const posts = await getAllPosts();

const main = [
  { href: "/", title: "Home" },
  { href: "/blog/", title: "Alle tips" },
  { href: "/theorie-tips/", title: "Theorie tips" },
  { href: "/rijbewijs-halen/", title: "Rijbewijs halen" },
  { href: "/over-ons/", title: "Over ons" },
  { href: "/contact/", title: "Contact" },
];
---
<BaseLayout title="Sitemap | AutotheorieTips" description="Overzicht van alle pagina's en tips op AutotheorieTips.">
  <Container class="py-(--spacing-section)">
    <h1 class="text-4xl font-black tracking-tight text-slate-900">Sitemap</h1>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">Hoofdpagina's</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {main.map((p) => <li><a class="text-teal-700 hover:underline" href={p.href}>{p.title}</a></li>)}
      </ul>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900">Alle tips ({posts.length})</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => <li><a class="text-teal-700 hover:underline" href={`/${p.id}/`}>{displayTitle(p)}</a></li>)}
      </ul>
    </section>
  </Container>
</BaseLayout>
